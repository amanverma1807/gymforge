---
import Layout from '../layouts/Layout.astro';
---

<Layout title="GymForge | Contact Us" description="Get in touch with the creator of GymForge for collaborations or feedback.">
  <section class="px-4 sm:px-8 py-24 max-w-3xl mx-auto w-full flex-grow flex flex-col">
    <div class="flex flex-col gap-3 mb-10">
      <div class="flex items-center gap-2 text-xs font-mono text-gym-muted">
        <a href="/" class="hover:text-accent-lime transition-colors">Home</a>
        <span>/</span>
        <span class="text-white">Contact</span>
      </div>
      <h1 class="font-display font-extrabold text-3xl md:text-5xl text-white tracking-tight">
        Get in touch<span class="text-accent-lime">.</span>
      </h1>
      <p class="text-gym-muted mt-2">
        Have questions, feedback, or want to collaborate? Reach out through any of the channels below.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mt-8">
      <!-- Email Card -->
      <div class="relative group w-full transition-all duration-300 hover:-translate-y-1">
        <a href="mailto:aff030832@gmail.com" class="flex items-center gap-4 p-6 pr-14 sm:pr-6 rounded-2xl border border-gym-border bg-gym-card/40 hover:bg-gym-card/80 transition-all duration-300 hover:border-accent-lime/60 text-left cursor-pointer relative z-10 pointer-events-auto w-full h-full">
          <div class="w-10 h-10 rounded-xl bg-accent-lime/10 border border-accent-lime/30 flex items-center justify-center text-accent-lime transition-transform group-hover:scale-110 shrink-0">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div class="flex flex-col min-w-0">
            <h3 class="text-white font-bold mb-0.5">Email Us</h3>
            <p class="text-gym-muted text-sm break-words">aff030832@gmail.com</p>
          </div>
        </a>
        <button 
          id="copy-email"
          class="absolute top-3 right-3 z-20 p-2 rounded-lg bg-gym-dark/80 border border-gym-border text-gym-muted hover:text-accent-lime hover:border-accent-lime/50 transition-all duration-200"
          title="Copy email"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
          </svg>
          <span id="copy-tooltip" class="absolute bottom-full right-0 mb-2 px-2 py-1 bg-accent-lime text-gym-dark text-[10px] font-bold rounded opacity-0 pointer-events-none transition-opacity duration-200 whitespace-nowrap">
            Copied!
          </span>
        </button>
      </div>

      <!-- WhatsApp Card -->
      <div class="relative group w-full transition-all duration-300 hover:-translate-y-1">
        <a href="https://wa.me/919352859535" target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 p-6 pr-14 sm:pr-6 rounded-2xl border border-gym-border bg-gym-card/40 hover:bg-gym-card/80 transition-all duration-300 hover:border-green-500/60 text-left cursor-pointer relative z-10 pointer-events-auto w-full h-full">
          <div class="w-10 h-10 rounded-xl bg-green-500/10 border border-green-500/30 flex items-center justify-center text-green-500 transition-transform group-hover:scale-110 shrink-0">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </div>
          <div class="flex flex-col min-w-0">
            <h3 class="text-white font-bold mb-0.5">WhatsApp</h3>
            <p class="text-gym-muted text-sm break-words">+91 93528 59535</p>
          </div>
        </a>
        <button 
          id="copy-phone"
          class="absolute top-3 right-3 z-20 p-2 rounded-lg bg-gym-dark/80 border border-gym-border text-gym-muted hover:text-green-500 hover:border-green-500/50 transition-all duration-200"
          title="Copy number"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
          </svg>
          <span id="phone-tooltip" class="absolute bottom-full right-0 mb-2 px-2 py-1 bg-green-500 text-white text-[10px] font-bold rounded opacity-0 pointer-events-none transition-opacity duration-200 whitespace-nowrap">
            Copied!
          </span>
        </button>
      </div>
    </div>
  </section>

  <script is:inline>
    // Copy Functionality
    function setupCopy(btnId, tooltipId, textToCopy) {
      const btn = document.getElementById(btnId);
      const tooltip = document.getElementById(tooltipId);
      
      if (btn && tooltip) {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          
          navigator.clipboard.writeText(textToCopy).then(() => {
            tooltip.classList.remove('opacity-0');
            tooltip.classList.add('opacity-100');
            
            setTimeout(() => {
              tooltip.classList.remove('opacity-100');
              tooltip.classList.add('opacity-0');
            }, 2000);
          }).catch(err => {
            console.error('Failed to copy: ', err);
          });
        });
      }
    }

    setupCopy('copy-email', 'copy-tooltip', 'aff030832@gmail.com');
    setupCopy('copy-phone', 'phone-tooltip', '+919352859535');
  </script>
</Layout>
