---
import Layout from '../../layouts/Layout.astro';
---

<Layout 
  title="GymForge | One Rep Max Calculator - Free Strength & Gym Calculator" 
  description="Free one rep max (1RM) calculator for lifters. Estimate your maximum lift capacity, training percentages, and RPE grids. High-performance gym tools by GymForge."
>
  <section class="px-4 sm:px-8 py-12 max-w-4xl mx-auto w-full flex-grow flex flex-col justify-center">
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-3 mb-10">
      <div class="flex items-center gap-2 text-xs font-mono text-gym-muted">
        <a href="/" class="hover:text-accent-lime transition-colors">Home</a>
        <span>/</span>
        <span class="text-white">One Rep Max</span>
      </div>
      <h1 class="font-display font-extrabold text-3xl md:text-5xl text-white tracking-tight">
        One rep max calculator<span class="text-accent-lime">.</span>
      </h1>
      <p class="text-gym-muted max-w-xl">
        Estimate your single-rep maximal lifting capacity and generate training percentage charts.
      </p>
    </div>

    <!-- Coming Soon Premium Card -->
    <div class="rounded-2xl border border-gym-border bg-gym-card p-8 shadow-2xl relative overflow-hidden flex flex-col md:flex-row gap-8 items-center">
      <!-- Glow accent -->
      <div class="absolute -left-16 -bottom-16 w-32 h-32 rounded-full bg-accent-cyan/10 blur-2xl"></div>

      <!-- Left Side: Interactive Graphic Mock -->
      <div class="w-full md:w-1/2 flex flex-col gap-4 p-6 rounded-xl bg-gym-dark/50 border border-gym-border relative select-none">
        <div class="flex items-center justify-between border-b border-gym-border pb-3">
          <span class="text-xs font-mono text-gym-muted">Percentage Breakdown</span>
          <span class="text-xs font-mono text-accent-cyan font-bold">1RM: 140 kg</span>
        </div>
        
        <div class="flex flex-col gap-2.5">
          <!-- 100% -->
          <div class="flex items-center justify-between text-xs">
            <span class="text-zinc-400 font-mono">100% (1 Rep)</span>
            <span class="text-white font-mono font-bold">140.0 kg</span>
          </div>
          <div class="w-full bg-zinc-800 h-1.5 rounded-full overflow-hidden">
            <div class="bg-accent-cyan h-full rounded-full" style="width: 100%"></div>
          </div>
          <!-- 90% -->
          <div class="flex items-center justify-between text-xs">
            <span class="text-zinc-400 font-mono">90% (3 Reps)</span>
            <span class="text-white font-mono font-bold">126.0 kg</span>
          </div>
          <div class="w-full bg-zinc-800 h-1.5 rounded-full overflow-hidden">
            <div class="bg-accent-cyan h-full rounded-full" style="width: 90%"></div>
          </div>
          <!-- 80% -->
          <div class="flex items-center justify-between text-xs">
            <span class="text-zinc-400 font-mono">80% (6 Reps)</span>
            <span class="text-white font-mono font-bold">112.0 kg</span>
          </div>
          <div class="w-full bg-zinc-800 h-1.5 rounded-full overflow-hidden">
            <div class="bg-accent-cyan h-full rounded-full" style="width: 80%"></div>
          </div>
        </div>

        <div class="absolute inset-0 bg-gradient-to-t from-gym-card via-transparent to-transparent flex items-center justify-center backdrop-blur-[2px]">
          <span class="px-3 py-1.5 rounded-lg border border-accent-cyan/30 bg-gym-card font-mono text-xs text-accent-cyan font-bold uppercase tracking-wider shadow-[0_0_12px_rgba(34,211,238,0.2)]">
            Under Development
          </span>
        </div>
      </div>

      <!-- Right Side: Text & Actions -->
      <div class="w-full md:w-1/2 flex flex-col gap-6">
        <div>
          <span class="text-xs font-mono font-bold text-accent-cyan uppercase tracking-wider bg-accent-cyan/10 px-2 py-0.5 rounded">Coming Soon</span>
          <h3 class="font-display font-bold text-2xl text-white mt-3">Planned features:</h3>
          <ul class="text-sm text-gym-muted mt-3 space-y-2.5">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-accent-lime shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Calculates using 5 standard formulas.
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-accent-lime shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Generates custom RPE percentage grids.
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-accent-lime shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Tracks warm-up sequence loads.
            </li>
          </ul>
        </div>

        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/" class="w-full sm:w-auto px-5 py-3 text-center text-xs font-semibold text-gym-dark bg-accent-lime hover:bg-accent-lime-hover rounded-full transition-all hover:scale-105">
            Back to Home
          </a>
          <a href="/tools/plate-calculator" class="w-full sm:w-auto px-5 py-3 text-center text-xs font-semibold text-white bg-gym-dark border border-gym-border hover:border-gym-border-strong rounded-full transition-all">
            Try Plate Calculator
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
