---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="GymForge | Calorie Calculator (Coming Soon)" description="Calculate daily calories and macro splits for training goals. Tool coming soon.">
  <section class="px-4 sm:px-8 py-12 max-w-4xl mx-auto w-full flex-grow flex flex-col justify-center">
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-3 mb-10">
      <div class="flex items-center gap-2 text-xs font-mono text-gym-muted">
        <a href="/" class="hover:text-accent-lime transition-colors">Home</a>
        <span>/</span>
        <span class="text-white">Calorie Calculator</span>
      </div>
      <h1 class="font-display font-extrabold text-3xl md:text-5xl text-white tracking-tight">
        Calorie calculator<span class="text-accent-lime">.</span>
      </h1>
      <p class="text-gym-muted max-w-xl">
        Calculate your Total Daily Energy Expenditure (TDEE) and macronutrient breakdown for bulk, cut, or maintenance.
      </p>
    </div>

    <!-- Coming Soon Premium Card -->
    <div class="rounded-2xl border border-gym-border bg-gym-card p-8 shadow-2xl relative overflow-hidden flex flex-col md:flex-row gap-8 items-center">
      <!-- Glow accent -->
      <div class="absolute -left-16 -top-16 w-32 h-32 rounded-full bg-accent-lime/10 blur-2xl"></div>

      <!-- Left Side: Interactive Graphic Mock -->
      <div class="w-full md:w-1/2 flex flex-col gap-4 p-6 rounded-xl bg-gym-dark/50 border border-gym-border relative select-none">
        <div class="flex items-center justify-between border-b border-gym-border pb-3">
          <span class="text-xs font-mono text-gym-muted">Macro Split Target</span>
          <span class="text-xs font-mono text-accent-lime font-bold">2,600 kcal</span>
        </div>
        
        <!-- Pie/Bar splits mock -->
        <div class="flex flex-col gap-3">
          <div class="flex items-center justify-between text-xs font-mono">
            <span class="text-white">Protein (40%)</span>
            <span class="text-accent-lime font-bold">260g</span>
          </div>
          <div class="w-full bg-zinc-800 h-2.5 rounded-full overflow-hidden">
            <div class="bg-accent-lime h-full rounded-full" style="width: 40%"></div>
          </div>
          
          <div class="flex items-center justify-between text-xs font-mono">
            <span class="text-white">Carbohydrates (40%)</span>
            <span class="text-accent-cyan font-bold">260g</span>
          </div>
          <div class="w-full bg-zinc-800 h-2.5 rounded-full overflow-hidden">
            <div class="bg-accent-cyan h-full rounded-full" style="width: 40%"></div>
          </div>

          <div class="flex items-center justify-between text-xs font-mono">
            <span class="text-white">Fats (20%)</span>
            <span class="text-accent-orange font-bold">58g</span>
          </div>
          <div class="w-full bg-zinc-800 h-2.5 rounded-full overflow-hidden">
            <div class="bg-accent-orange h-full rounded-full" style="width: 20%"></div>
          </div>
        </div>

        <div class="absolute inset-0 bg-gradient-to-t from-gym-card via-transparent to-transparent flex items-center justify-center backdrop-blur-[2px]">
          <span class="px-3 py-1.5 rounded-lg border border-accent-lime/30 bg-gym-card font-mono text-xs text-accent-lime font-bold uppercase tracking-wider shadow-[0_0_12px_rgba(163,230,53,0.2)]">
            Under Development
          </span>
        </div>
      </div>

      <!-- Right Side: Text & Actions -->
      <div class="w-full md:w-1/2 flex flex-col gap-6">
        <div>
          <span class="text-xs font-mono font-bold text-accent-lime uppercase tracking-wider bg-accent-lime/10 px-2 py-0.5 rounded">Coming Soon</span>
          <h3 class="font-display font-bold text-2xl text-white mt-3">Planned features:</h3>
          <ul class="text-sm text-gym-muted mt-3 space-y-2.5">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-accent-lime shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Calculates TDEE using Mifflin-St Jeor and Katch-McArdle formulas.
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-accent-lime shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Adjusts targets dynamically based on workout activity profiles.
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-accent-lime shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Exports simple macro layouts to PDF or clipboard text formats.
            </li>
          </ul>
        </div>

        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/" class="w-full sm:w-auto px-5 py-3 text-center text-xs font-semibold text-gym-dark bg-accent-lime hover:bg-accent-lime-hover rounded-full transition-all hover:scale-105">
            Back to Home
          </a>
          <a href="/tools/plate-calculator" class="w-full sm:w-auto px-5 py-3 text-center text-xs font-semibold text-white bg-gym-dark border border-gym-border hover:border-gym-border-strong rounded-full transition-all">
            Try Plate Calculator
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
