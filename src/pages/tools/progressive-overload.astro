---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="GymForge | Progressive Overload Planner (Coming Soon)" description="Map out training intensity cycles and progressive overload blocks. Tool coming soon.">
  <section class="px-4 sm:px-8 py-12 max-w-4xl mx-auto w-full flex-grow flex flex-col justify-center">
    <!-- Breadcrumb & Header -->
    <div class="flex flex-col gap-3 mb-10">
      <div class="flex items-center gap-2 text-xs font-mono text-gym-muted">
        <a href="/" class="hover:text-accent-lime transition-colors">Home</a>
        <span>/</span>
        <span class="text-white">Overload Planner</span>
      </div>
      <h1 class="font-display font-extrabold text-3xl md:text-5xl text-white tracking-tight">
        Progressive overload planner<span class="text-accent-lime">.</span>
      </h1>
      <p class="text-gym-muted max-w-xl">
        Map out weekly volume, intensity transitions, and fatigue cycles to push past strength sticking points.
      </p>
    </div>

    <!-- Coming Soon Premium Card -->
    <div class="rounded-2xl border border-gym-border bg-gym-card p-8 shadow-2xl relative overflow-hidden flex flex-col md:flex-row gap-8 items-center">
      <!-- Glow accent -->
      <div class="absolute -right-16 -top-16 w-32 h-32 rounded-full bg-accent-orange/10 blur-2xl"></div>

      <!-- Left Side: Interactive Graphic Mock -->
      <div class="w-full md:w-1/2 flex flex-col gap-4 p-6 rounded-xl bg-gym-dark/50 border border-gym-border relative select-none">
        <div class="flex items-center justify-between border-b border-gym-border pb-3">
          <span class="text-xs font-mono text-gym-muted">Squat Cycle (4 Weeks)</span>
          <span class="text-xs font-mono text-accent-orange font-bold">Linear Load</span>
        </div>
        
        <!-- Bars mock chart -->
        <div class="flex justify-between items-end h-28 px-4 py-2 bg-zinc-900/50 rounded-lg">
          <div class="flex flex-col items-center gap-2 w-8">
            <span class="text-[9px] font-mono text-zinc-500">W1</span>
            <div class="w-full bg-accent-orange/40 h-12 rounded-t-sm"></div>
          </div>
          <div class="flex flex-col items-center gap-2 w-8">
            <span class="text-[9px] font-mono text-zinc-500">W2</span>
            <div class="w-full bg-accent-orange/60 h-16 rounded-t-sm"></div>
          </div>
          <div class="flex flex-col items-center gap-2 w-8">
            <span class="text-[9px] font-mono text-zinc-500">W3</span>
            <div class="w-full bg-accent-orange/80 h-20 rounded-t-sm"></div>
          </div>
          <div class="flex flex-col items-center gap-2 w-8">
            <span class="text-[9px] font-mono text-accent-orange font-bold">W4</span>
            <div class="w-full bg-accent-orange h-24 rounded-t-sm shadow-[0_0_8px_rgba(249,115,22,0.3)]"></div>
          </div>
        </div>

        <div class="absolute inset-0 bg-gradient-to-t from-gym-card via-transparent to-transparent flex items-center justify-center backdrop-blur-[2px]">
          <span class="px-3 py-1.5 rounded-lg border border-accent-orange/30 bg-gym-card font-mono text-xs text-accent-orange font-bold uppercase tracking-wider shadow-[0_0_12px_rgba(249,115,22,0.2)]">
            Under Development
          </span>
        </div>
      </div>

      <!-- Right Side: Text & Actions -->
      <div class="w-full md:w-1/2 flex flex-col gap-6">
        <div>
          <span class="text-xs font-mono font-bold text-accent-orange uppercase tracking-wider bg-accent-orange/10 px-2 py-0.5 rounded">Coming Soon</span>
          <h3 class="font-display font-bold text-2xl text-white mt-3">Planned features:</h3>
          <ul class="text-sm text-gym-muted mt-3 space-y-2.5">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-accent-lime shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Supports Linear, Wave, and Block progression models.
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-accent-lime shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Generates auto-regulatory RPE target suggestions.
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-accent-lime shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Calculates relative volume indices per workout.
            </li>
          </ul>
        </div>

        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/" class="w-full sm:w-auto px-5 py-3 text-center text-xs font-semibold text-gym-dark bg-accent-lime hover:bg-accent-lime-hover rounded-full transition-all hover:scale-105">
            Back to Home
          </a>
          <a href="/tools/plate-calculator" class="w-full sm:w-auto px-5 py-3 text-center text-xs font-semibold text-white bg-gym-dark border border-gym-border hover:border-gym-border-strong rounded-full transition-all">
            Try Plate Calculator
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
