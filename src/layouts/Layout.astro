---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
}

const { 
  title = "GymForge | Premium Fitness Toolkit", 
  description = "A suite of modern gym calculators and strength utilities to forge your lifting performance.",
  image = "/apple-touch-icon.png", // Default image
  canonical: canonicalProp
} = Astro.props;

// Use Astro.site to ensure we always use the primary domain for canonicals
const canonicalURL = canonicalProp || new URL(Astro.url.pathname, Astro.site).toString();
const siteName = "GymForge";
const twitterHandle = "@GymForge"; // Placeholder or user choice
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="GymForge" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary SEO Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content="GymForge, gym calculator, gym tools, gym toolkit, free gym calculator, gym plate calculator, plate calculator, barbell plate calculator, weight plate calculator, kg plate calculator, kilo plate calculator" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />
    <meta property="og:site_name" content={siteName} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.url)} />

    <!-- Structured Data -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "GymForge",
        "alternateName": "GymForge Fitness Toolkit",
        "url": "https://gymforge.online",
        "description": "A suite of modern gym calculators and strength utilities to forge your lifting performance."
      }
    </script>
    
    <script is:inline>
      // Client-side redirect fallback for www to non-www
      if (window.location.hostname === 'www.gymforge.online') {
        window.location.replace('https://gymforge.online' + window.location.pathname + window.location.search);
      }
    </script>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Outfit:wght@500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-3SNW52QPLY"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-3SNW52QPLY');
    </script>
  </head>
  <body class="bg-gym-dark text-gym-text min-h-screen flex flex-col mesh-gradient-bg">
    <!-- Header -->
    <header class="sticky top-0 z-50 glass-panel h-16 w-full px-4 sm:px-8 flex items-center justify-between transition-all duration-300">
      <div class="flex items-center gap-3">
        <a href="/" class="flex items-center gap-3 group">
          <!-- Logo Icon -->
          <img 
            src="/favicon.svg" 
            alt="GymForge Logo" 
            class="w-8 h-8 md:w-10 md:h-10 transition-transform group-hover:scale-105"
            width="40"
            height="40"
            loading="eager"
            decoding="async"
          />
          <span class="font-display font-extrabold text-xl tracking-tight text-white group-hover:text-accent-lime transition-colors">
            Gym<span class="text-accent-lime">Forge</span>
          </span>
        </a>
      </div>

      <!-- Navigation links (Desktop) -->
      <nav class="hidden md:flex items-center gap-6">
        <a href="/" class="text-sm font-medium hover:text-accent-lime transition-colors text-gym-muted hover:text-white">Home</a>
        <a href="/training-tracker" class="text-sm font-medium hover:text-accent-lime transition-colors text-gym-muted hover:text-white">Training Tracker</a>
        <a href="/tools/plate-calculator" class="text-sm font-medium hover:text-accent-lime transition-colors text-gym-muted hover:text-white">Plate Calculator</a>
        
        <div class="relative group/menu">
          <button class="flex items-center gap-1 text-sm font-medium text-gym-muted hover:text-white transition-colors py-2 cursor-pointer">
            More Tools
            <svg class="w-4 h-4 transition-transform group-hover/menu:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          
          <div class="absolute right-0 top-full mt-1 w-64 glass-panel rounded-xl py-2 shadow-2xl opacity-0 translate-y-2 pointer-events-none group-hover/menu:opacity-100 group-hover/menu:translate-y-0 group-hover/menu:pointer-events-auto transition-all duration-200">
            <a href="/tools/one-rep-max" class="flex items-center px-4 py-2 text-sm text-gym-muted hover:text-accent-lime hover:bg-zinc-800/40 transition-colors">
              One Rep Max Calculator
            </a>
            <a href="/tools/progressive-overload" class="flex items-center px-4 py-2 text-sm text-gym-muted hover:text-accent-lime hover:bg-zinc-800/40 transition-colors">
              Progressive Overload Planner
            </a>
            <a href="/tools/calorie" class="flex items-center px-4 py-2 text-sm text-gym-muted hover:text-accent-lime hover:bg-zinc-800/40 transition-colors">
              Calorie Calculator
            </a>
            <a href="/tools/protein" class="flex items-center px-4 py-2 text-sm text-gym-muted hover:text-accent-lime hover:bg-zinc-800/40 transition-colors">
              Protein Calculator
            </a>
            <a href="/tools/strength-standards" class="flex items-center px-4 py-2 text-sm text-gym-muted hover:text-accent-lime hover:bg-zinc-800/40 transition-colors">
              Strength Standards
            </a>
          </div>
        </div>
      </nav>

      <!-- CTA (Desktop) -->
      <div class="hidden md:block">
        <a href="/tools/plate-calculator" class="px-4 py-2 text-xs font-semibold text-gym-dark bg-accent-lime hover:bg-accent-lime-hover rounded-full transition-all hover:scale-105 shadow-[0_0_12px_rgba(163,230,53,0.25)]">
          Start Calculating
        </a>
      </div>

      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" aria-label="Toggle navigation menu" class="md:hidden w-10 h-10 flex items-center justify-center text-gym-muted hover:text-white rounded-lg border border-gym-border hover:border-gym-border-strong transition-colors cursor-pointer">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path id="menu-btn-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
        </svg>
      </button>

      <!-- Mobile Navigation Drawer -->
      <div id="mobile-menu" class="fixed inset-x-0 top-16 bg-gym-dark/95 backdrop-blur-lg border-b border-gym-border flex flex-col py-6 px-6 gap-6 shadow-2xl md:hidden opacity-0 translate-y-[-10px] pointer-events-none transition-all duration-300 z-40">
        <a href="/" class="text-lg font-medium text-gym-muted hover:text-white hover:text-accent-lime transition-colors">Home</a>
        <a href="/training-tracker" class="text-lg font-medium text-gym-muted hover:text-white hover:text-accent-lime transition-colors">Training Tracker</a>
        <a href="/tools/plate-calculator" class="text-lg font-medium text-gym-muted hover:text-white hover:text-accent-lime transition-colors">Plate Calculator</a>
        <div class="w-full h-[1px] bg-gym-border my-1"></div>
        <span class="text-xs font-bold uppercase text-accent-lime tracking-wider">Other Toolkit Tools</span>
        <a href="/tools/one-rep-max" class="text-base text-gym-muted hover:text-white hover:text-accent-lime transition-colors pl-2">One Rep Max Calculator</a>
        <a href="/tools/progressive-overload" class="text-base text-gym-muted hover:text-white hover:text-accent-lime transition-colors pl-2">Progressive Overload Planner</a>
        <a href="/tools/calorie" class="text-base text-gym-muted hover:text-white hover:text-accent-lime transition-colors pl-2">Calorie Calculator</a>
        <a href="/tools/protein" class="text-base text-gym-muted hover:text-white hover:text-accent-lime transition-colors pl-2">Protein Calculator</a>
        <a href="/tools/strength-standards" class="text-base text-gym-muted hover:text-white hover:text-accent-lime transition-colors pl-2">Strength Standards</a>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow flex flex-col relative z-10">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-gym-border bg-gym-dark/80 px-4 sm:px-8 py-12 flex flex-col md:flex-row justify-between items-start md:items-center gap-8 text-sm">
      <div class="flex flex-col gap-3 max-w-sm">
        <div class="flex items-center gap-3">
          <img 
            src="/favicon.svg" 
            alt="GymForge Logo" 
            class="w-6 h-6 transition-transform hover:scale-105"
            width="24"
            height="24"
            loading="lazy"
            decoding="async"
          />
          <span class="font-display font-extrabold text-base tracking-tight text-white">
            Gym<span class="text-accent-lime">Forge</span>
          </span>
        </div>
        <p class="text-gym-muted leading-relaxed">
          Premium gym tools, calculators, and trackers built for powerlifters, bodybuilders, and fitness enthusiasts.
        </p>
      </div>

      <div class="flex flex-wrap gap-x-12 gap-y-6">
        <div class="flex flex-col gap-2">
          <span class="font-bold text-xs uppercase tracking-wider text-accent-lime">Tools</span>
          <a href="/training-tracker" class="text-gym-muted hover:text-white transition-colors">Training Tracker</a>
          <a href="/tools/plate-calculator" class="text-gym-muted hover:text-white transition-colors">Plate Calculator</a>
          <a href="/tools/one-rep-max" class="text-gym-muted hover:text-white transition-colors">1RM Calculator</a>
          <a href="/tools/progressive-overload" class="text-gym-muted hover:text-white transition-colors">Overload Planner</a>
        </div>
        
        <div class="flex flex-col gap-2">
          <span class="font-bold text-xs uppercase tracking-wider text-accent-lime">Health</span>
          <a href="/tools/calorie" class="text-gym-muted hover:text-white transition-colors">Calorie Calculator</a>
          <a href="/tools/protein" class="text-gym-muted hover:text-white transition-colors">Protein Calculator</a>
          <a href="/tools/strength-standards" class="text-gym-muted hover:text-white transition-colors">Strength Standards</a>
        </div>

        <div class="flex flex-col gap-2">
          <span class="font-bold text-xs uppercase tracking-wider text-accent-lime">GymForge</span>
          <a href="/about" class="text-gym-muted hover:text-white transition-colors">About Us</a>
          <a href="/contact" class="text-gym-muted hover:text-white transition-colors">Contact</a>
          <a href="/privacy-policy" class="text-gym-muted hover:text-white transition-colors">Privacy Policy</a>
          <a href="/terms" class="text-gym-muted hover:text-white transition-colors">Terms of Service</a>
        </div>
      </div>

      <div class="flex flex-col gap-2 max-w-xs md:text-right md:items-end">
        <span class="text-xs font-semibold text-gym-muted">Safety Disclaimer</span>
        <p class="text-xs text-gym-muted leading-relaxed italic md:text-right">
          Disclaimer: Consult a certified coach or medical professional before attempting intense lifts or heavy weights. Safety first.
        </p>
        <span class="text-xs text-gym-muted mt-2">&copy; {new Date().getFullYear()} GymForge. Created & Maintained by Aman Verma. All rights reserved.</span>
      </div>
    </footer>

    <!-- Script for mobile menu interaction -->
    <script>
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const menuIcon = document.getElementById('menu-btn-icon');

      if (mobileMenuBtn && mobileMenu) {
        mobileMenuBtn.addEventListener('click', () => {
          const isOpened = mobileMenu.classList.contains('opacity-100');
          if (isOpened) {
            mobileMenu.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
            mobileMenu.classList.add('opacity-0', 'translate-y-[-10px]', 'pointer-events-none');
            if (menuIcon) {
              menuIcon.setAttribute('d', 'M4 6h16M4 12h16m-7 6h7');
            }
          } else {
            mobileMenu.classList.remove('opacity-0', 'translate-y-[-10px]', 'pointer-events-none');
            mobileMenu.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
            if (menuIcon) {
              menuIcon.setAttribute('d', 'M6 18L18 6M6 6l12 12');
            }
          }
        });
      }
    </script>
  </body>
</html>
